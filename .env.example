# ─── apps/web (prefix NEXT_PUBLIC_ for browser-exposed vars) ───
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXTAUTH_SECRET=                                  # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── apps/api (never exposed to browser) ───
PORT=4000
WEB_URL=http://localhost:3000
PDFLATEX_PATH=                                  # optional full path to pdflatex.exe if not on PATH
ANTHROPIC_API_KEY=sk-ant-...
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...                  # service role, NOT anon key
