{
  "name": "resumeai",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@resumeai/web",
    "dev:api": "turbo run dev --filter=@resumeai/api",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@resumeai/web",
    "build:api": "turbo run build --filter=@resumeai/api",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0"
}
